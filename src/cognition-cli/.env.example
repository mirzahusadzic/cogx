# =============================================================================
# Cognition CLI - Environment Configuration
# =============================================================================
# Copy this file to .env and customize as needed:
#   cp .env.example .env
#
# Most settings have sensible defaults and are optional.
# =============================================================================

# -----------------------------------------------------------------------------
# eGemma Workbench Configuration
# -----------------------------------------------------------------------------
# URL for the eGemma Workbench server (used for embeddings and advanced features)
# Default: http://localhost:8000
# WORKBENCH_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Terminal Output Configuration
# -----------------------------------------------------------------------------
# These settings control how the CLI renders output in your terminal.
# They are auto-detected but can be overridden for specific environments.

# Disable colored output (useful for CI/CD or unsupported terminals)
# Values: 1 (disable) or 0 (enable, default)
# COGNITION_NO_COLOR=0

# Disable emoji output (useful for terminals without Unicode support)
# Values: 1 (disable) or 0 (enable, default)
# COGNITION_NO_EMOJI=0

# Force output format
# Values: auto (default), plain, fancy
# COGNITION_FORMAT=auto

# Enable verbose logging globally
# Values: 1 (enable) or 0 (disable, default)
# COGNITION_VERBOSE=0

# Enable quiet mode (minimal output)
# Values: 1 (enable) or 0 (disable, default)
# COGNITION_QUIET=0

# Standard NO_COLOR environment variable (alternative to COGNITION_NO_COLOR)
# See: https://no-color.org/
# NO_COLOR=

# -----------------------------------------------------------------------------
# Development & Debugging
# -----------------------------------------------------------------------------
# Node.js environment (usually auto-detected)
# Values: development, production, test
# NODE_ENV=development

# Enable debug logging for specific modules
# Example: DEBUG=cognition:*
# DEBUG=

# -----------------------------------------------------------------------------
# API Keys (Optional - for LLM-based features)
# -----------------------------------------------------------------------------
# These are only needed if you're using LLM-based overlay generation

# OpenAI API Key (for GPT-based features)
# OPENAI_API_KEY=

# Anthropic API Key (for Claude-based features)
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Advanced Configuration
# -----------------------------------------------------------------------------
# Custom locale setting (auto-detected from system)
# LANG=en_US.UTF-8

# Terminal type (auto-detected)
# TERM=xterm-256color

# CI environment detection (auto-detected in CI/CD)
# CI=
